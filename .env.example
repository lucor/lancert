# lancert.dev configuration
# Copy to .env and adjust values for your deployment.
# CLI flags (e.g. -server-ip) override these.

# Required: public IP of this server (used for DNS A records)
LANCERT_SERVER_IP=

# Listen addresses
LANCERT_DNS_ADDR=:53
LANCERT_HTTP_ADDR=:8443

# Data directory for certs and keys
LANCERT_DATA_DIR=data

# ACME account key path
LANCERT_ACCOUNT_KEY=data/account-key.pem

# Email for Let's Encrypt account (optional)
LANCERT_EMAIL=

# DNS zone (with or without trailing dot)
LANCERT_ZONE=lancert.dev.

# Use Let's Encrypt staging environment
LANCERT_STAGING=false

# Skip certificate pre-generation at startup
LANCERT_NO_PREGEN=false
